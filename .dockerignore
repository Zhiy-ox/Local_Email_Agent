# Keep the build context (and image) lean: only api_server.py, llm_client.py,
# requirements.txt and ui/ are needed. Everything below is host-only or dev junk.
.git
.gitignore
.claude/
.codex/
__pycache__/
*.py[cod]

# Runtime state (mounted as volumes at run time, not baked into the image)
logs/
state/
config.json

# Host-only: macOS AppleScript worker + automation
agent_mail_calendar.py
agent_calendar_only.py
scripts/

# Not needed at runtime
EmailAgentUI/
design-system/
*.md
ui/email-agent-standalone.html
